#include <stdio.h>
int main() {
    int a[10][10],b[10][10],x[10][10],y[10][10];
    int m,n;

    printf("Enter row and column: ");
    scanf("%d%d",&m,&n);

    printf("Enter 1st Matrix:\n");
    for(int i=0;i<m;i++) {
        for(int j=0;j<n;j++) {
            scanf("%d",&a[i][j]);
        }
    }
    printf("Enter elements of second matrix:\n");
    for(int i=0;i<m;i++) {
        for(int j=0;j<n;j++) {
            scanf("%d",&b[i][j]);
        }
    }
    for(int i=0;i<m;i++) {
        for(int j=0;j<n;j++) {
            x[i][j]=a[i][j] + b[i][j];
            y[i][j]=a[i][j] - b[i][j];
        }
    }
    printf("\nAddition of matrices:\n");
    for(int i=0;i<m;i++) {
        for(int j=0;j<n;j++) {
            printf("%d ",x[i][j]);
        }
        printf("\n");
    }
    printf("\nSubtraction of matrices:\n");
    for(int i=0;i<m;i++) {
        for(int j=0;j<n;j++) {
            printf("%d ",y[i][j]);
        }
        printf("\n");
    }
    return 0;
}
